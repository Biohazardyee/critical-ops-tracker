# ---- Critical Ops API ----
# Public Critical Force endpoint (community-documented, no key required).
COPS_API_BASE=https://default.prod.copsapi.criticalforce.fi/api/public

# ---- Database (PostgreSQL) ----
# Credentials for the Postgres "db" service in docker-compose.yml.
POSTGRES_USER=cops
POSTGRES_PASSWORD=change-me
POSTGRES_DB=cops
# Connection string used by the API / worker / bot.
# Local (host) dev against the compose Postgres published on localhost:
DATABASE_URL=postgresql://cops:change-me@localhost:5433/cops?schema=public
# NOTE: inside Docker, compose overrides DATABASE_URL to use host "db".

# ---- API server ----
API_PORT=8787

# ---- Web (Vite) ----
# Leave empty: the Vite dev server (and nginx in prod) proxy /api to the API.
VITE_API_URL=

# ---- Worker (snapshots) ----
# Cron expression for periodic snapshots (default: every day at 04:00).
SNAPSHOT_CRON=0 4 * * *

# ---- Discord bot (optional) ----
# Enable with: docker compose --profile bot up -d
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to a single guild during dev.
DISCORD_GUILD_ID=
