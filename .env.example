# ---- Critical Ops API ----
# Public Critical Force endpoint (community-documented, no key required).
COPS_API_BASE=https://default.prod.copsapi.criticalforce.fi/api/public

# ---- Database (SQLite via Prisma) ----
# Path is resolved relative to packages/db/prisma/schema.prisma
DATABASE_URL=file:./dev.db

# ---- API server ----
API_PORT=8787

# ---- Web (Vite) ----
# Leave empty in dev: the Vite dev server proxies /api to the API server.
# In production set it to the API origin, e.g. https://api.yourdomain.com
VITE_API_URL=

# ---- Worker (snapshots) ----
# Cron expression for periodic snapshots (default: every day at 04:00).
SNAPSHOT_CRON=0 4 * * *

# ---- Discord bot ----
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash commands instantly to a single guild during dev.
DISCORD_GUILD_ID=
