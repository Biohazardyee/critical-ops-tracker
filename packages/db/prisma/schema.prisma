// Critical Ops Tracker — persistence layer (PostgreSQL).
// Schema is applied with `prisma db push` (see the `migrate` service in
// docker-compose.yml and the db package scripts).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A player we take periodic snapshots of, to build a local history.
model TrackedPlayer {
  /// Critical Ops userID (stored as string to be safe with large ids).
  userId    String     @id
  name      String
  addedAt   DateTime   @default(now())
  snapshots Snapshot[]
}

/// A point-in-time capture of a tracked player's headline stats.
model Snapshot {
  id            Int           @id @default(autoincrement())
  player        TrackedPlayer @relation(fields: [userId], references: [userId], onDelete: Cascade)
  userId        String
  takenAt       DateTime      @default(now())

  level         Int
  mmr           Int
  rank          Int

  // Career ranked totals at capture time (summed across seasons).
  rankedKills   Int
  rankedDeaths  Int
  rankedAssists Int
  rankedWins    Int
  rankedLosses  Int

  /// Full raw profile JSON, kept for future-proofing / re-deriving metrics.
  raw           String

  @@index([userId, takenAt])
}

/// A rank / MMR change detected by the worker — surfaced as in-app notifications.
model RankEvent {
  id      Int      @id @default(autoincrement())
  userId  String
  name    String
  at      DateTime @default(now())
  kind    String // "rank_up" | "rank_down" | "mmr"
  oldRank Int
  newRank Int
  oldMmr  Int
  newMmr  Int

  @@index([userId, at])
}

/// A device token following a player (drives the per-token notification feed).
model Follow {
  token     String
  userId    String
  name      String
  createdAt DateTime @default(now())

  @@id([token, userId])
  @@index([token])
}
